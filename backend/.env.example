# App
APP_NAME="AI Voice Call Platform"
APP_ENV=development          # development | staging | production
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
ALLOWED_HOSTS=["*"]

# JWT
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=voicecall
POSTGRES_USER=voicecall
POSTGRES_PASSWORD=voicecall_dev_password
DATABASE_URL=postgresql+asyncpg://voicecall:voicecall_dev_password@localhost:5432/voicecall

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=voicecall_logs
MONGO_USER=voicecall
MONGO_PASSWORD=voicecall_dev_password
MONGO_URL=mongodb://voicecall:voicecall_dev_password@localhost:27017/voicecall_logs?authSource=admin

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_URL=redis://localhost:6379/1

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Telephony
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+84xxxxxxxxx
FREESWITCH_ESL_HOST=localhost
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon

# AI Services
LLAMA_CPP_BASE_URL=http://localhost:8080
WHISPER_MODEL_PATH=./models/phowhisper-small
XTTS_SERVER_URL=http://localhost:5002
QDRANT_COLLECTION_PREFIX=tenant_